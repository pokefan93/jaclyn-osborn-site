---
import NewsletterPanel from '../components/NewsletterPanel.astro';
import PageHero from '../components/PageHero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/withBase';
---

<BaseLayout
  title="Newsletter"
  description="Sign up for Jaclyn Osborn's newsletter."
>
  <PageHero
    eyebrow="Newsletter"
    title="Join Jaclyn's newsletter."
    description="Get release news, cover reveals, signed copy updates, and occasional notes from Jaclyn."
    actions={[
      { href: withBase('books/'), label: 'Browse books', variant: 'secondary' },
    ]}
  />

  <section class="px-4 pt-10 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <NewsletterPanel />
    </div>
  </section>

  <section class="px-4 pb-6 pt-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <div class="card-shell rounded-[2.3rem] p-6 text-center sm:p-8">
        <p class="eyebrow text-[#7c5a63]">What to expect</p>
        <h2 class="mt-4 font-display text-4xl text-[#241920] sm:text-5xl">
          News when there is news to share.
        </h2>
        <p class="mt-4 text-base leading-8 text-[#5d4b52] sm:text-lg">
          The newsletter is the easiest way to hear about new releases, cover reveals,
          and signed copy updates.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
