---
export const prerender = true;

import NewsletterPanel from '../components/NewsletterPanel.astro';
import PageHero from '../components/PageHero.astro';
import SocialShowcase from '../components/SocialShowcase.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteMeta } from '../data/site';
import { withBase } from '../utils/withBase';
---

<BaseLayout
  title="Newsletter"
  description="Join Jaclyn Osborn's newsletter for release updates and book news."
>
  <PageHero
    eyebrow="Newsletter"
    title="Join Jaclyn's newsletter"
    description="Get release updates, cover reveals, signed copy news, and the occasional note from Jaclyn."
    actions={[
      { href: withBase('books/'), label: 'Browse books', variant: 'secondary' },
      { href: siteMeta.instagramUrl, label: 'Follow on Instagram', variant: 'primary', external: true },
    ]}
    compact
  />

  <section class="px-4 pt-10 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <NewsletterPanel />
    </div>
  </section>

  <section class="px-4 pb-6 pt-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <SocialShowcase />
    </div>
  </section>
</BaseLayout>
