---
import NewsletterPanel from '../components/NewsletterPanel.astro';
import PageHero from '../components/PageHero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { newsletterArchive } from '../data/site';
import { withBase } from '../utils/withBase';
---

<BaseLayout
  title="Newsletter"
  description="Newsletter landing page with a static provider-ready signup form and seeded campaign ideas."
>
  <PageHero
    eyebrow="Newsletter"
    title="A reader letter built for launches, bonus content, and backlist discovery."
    description="Instead of a generic signup box, this page frames the newsletter as part of the storefront: a place to announce releases, surface hidden gems in the backlist, and give readers small emotional extras."
    actions={[
      { href: withBase('books/'), label: 'Browse the catalog', variant: 'secondary' },
    ]}
  />

  <section class="px-4 pt-10 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <NewsletterPanel />
    </div>
  </section>

  <section class="px-4 pb-6 pt-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="space-y-8">
        <div class="max-w-3xl space-y-4">
          <p class="eyebrow text-[#7c5a63]">Sample issue directions</p>
          <h2 class="font-display text-4xl text-[#241920] sm:text-5xl">
            Treat the newsletter archive like a curated extension of the brand.
          </h2>
          <p class="text-base leading-8 text-[#5d4b52] sm:text-lg">
            These cards are mock editorial directions, not real campaigns. They show how this static site can support a clear newsletter voice before a provider is wired in.
          </p>
        </div>

        <div class="grid gap-6 lg:grid-cols-3">
          {
            newsletterArchive.map((item) => (
              <article class="card-shell rounded-[2rem] p-6">
                <p class="eyebrow text-[#7c5a63]">Issue concept</p>
                <h3 class="mt-4 font-display text-3xl text-[#241920]">{item.title}</h3>
                <p class="mt-3 text-sm leading-7 text-[#5d4b52]">{item.copy}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
