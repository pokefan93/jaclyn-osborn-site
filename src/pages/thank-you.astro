---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterPanel from '../components/NewsletterPanel.astro';
import PageHero from '../components/PageHero.astro';
import { siteMeta } from '../data/site';
import { withBase } from '../utils/withBase';
---

<BaseLayout
  title="Thank You"
  description="Thank you for your order."
>
  <PageHero
    eyebrow="Thank you"
    title="Thank you for your order."
    description="A receipt should be on its way to your email. If you need help with your order, Jaclyn can be reached any time."
    actions={[
      { href: withBase('newsletter/'), label: 'Join the newsletter', variant: 'primary' },
      { href: siteMeta.instagramUrl, label: 'Follow on Instagram', variant: 'secondary', external: true },
    ]}
    centered
  />

  <section class="px-4 pt-10 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-[1fr_1fr]">
      <article class="card-shell rounded-[2.35rem] p-6 sm:p-8">
        <p class="eyebrow text-[#7c5a63]">What happens next</p>
        <h2 class="mt-4 font-display text-4xl text-[#241920] sm:text-5xl">
          Watch your email for order details.
        </h2>
        <div class="mt-6 space-y-3">
          <p class="purchase-note">
            Your receipt should arrive by email shortly after checkout.
          </p>
          <p class="purchase-note">
            If your order includes a preorder or signed copy, any updates will be
            shared by email.
          </p>
          <p class="purchase-note">
            If you need help, reply to your receipt or email{' '}
            <a href={`mailto:${siteMeta.email}`} class="font-semibold text-[#241920] underline decoration-[#cdaea5] underline-offset-4">
              {siteMeta.email}
            </a>
            .
          </p>
        </div>
      </article>

      <article class="card-shell rounded-[2.35rem] p-6 sm:p-8">
        <p class="eyebrow text-[#7c5a63]">Stay connected</p>
        <h2 class="mt-4 font-display text-4xl text-[#241920] sm:text-5xl">
          Keep up with new books and shop updates.
        </h2>
        <div class="mt-6 space-y-4">
          <a href={withBase('newsletter/')} class="button-secondary">
            Join the newsletter
          </a>
          <a href={siteMeta.instagramUrl} target="_blank" rel="noreferrer" class="button-secondary">
            Follow on Instagram
          </a>
          <p class="purchase-note">
            The newsletter and Instagram are the best places to hear about release
            news, cover reveals, and signed copy updates.
          </p>
        </div>
      </article>
    </div>
  </section>

  <section class="px-4 pb-6 pt-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <NewsletterPanel compact />
    </div>
  </section>
</BaseLayout>
