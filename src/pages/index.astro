---
import BookCard from '../components/BookCard.astro';
import BookCover from '../components/BookCover.astro';
import NewsletterPanel from '../components/NewsletterPanel.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SeriesCard from '../components/SeriesCard.astro';
import SocialShowcase from '../components/SocialShowcase.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { booksBySeries, catalogStats, featuredBooks } from '../data/catalog';
import { siteMeta, vibeCards } from '../data/site';
import { withBase } from '../utils/withBase';

const heroBooks = [featuredBooks[0], featuredBooks[1], booksBySeries[2]?.books[0]].filter(Boolean);
---

<BaseLayout>
  <section class="px-4 pt-8 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[1.08fr_0.92fr] lg:items-center">
      <div class="hero-shell animate-reveal overflow-hidden rounded-[2.85rem] px-6 py-10 sm:px-10 sm:py-14">
        <div class="relative z-10 max-w-2xl">
          <p class="eyebrow text-[#e7cec6]">{siteMeta.shortTagline}</p>
          <h1 class="mt-5 font-display text-[3.15rem] leading-[0.92] text-white sm:text-[4.65rem]">
            {siteMeta.heroTitle}
          </h1>
          <p class="mt-6 max-w-xl text-base leading-8 text-white/76 sm:text-lg">
            {siteMeta.heroCopy}
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href={withBase('books/')} class="button-primary">
              Browse books
            </a>
            <a href={withBase('series/')} class="button-secondary">
              Explore series
            </a>
            <a href={withBase('newsletter/')} class="button-secondary">
              Join the newsletter
            </a>
          </div>

          <div class="mt-10 grid gap-4 sm:grid-cols-3">
            <div class="stat-card">
              <span class="stat-number">{catalogStats.bookCount}</span>
              <span class="stat-label">sample titles</span>
            </div>
            <div class="stat-card">
              <span class="stat-number">{catalogStats.seriesCount}</span>
              <span class="stat-label">entry-point series</span>
            </div>
            <div class="stat-card">
              <span class="stat-number">5</span>
              <span class="stat-label">romance lanes</span>
            </div>
          </div>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-[0.9fr_1.1fr]">
        <div class="space-y-4">
          <div class="card-shell animate-card-delay-1 rounded-[2.25rem] p-4">
            <BookCover book={heroBooks[0]} />
          </div>
          <div class="card-shell animate-card-delay-2 rounded-[2.25rem] p-5">
            <p class="eyebrow text-[#7c5a63]">Backlist promise</p>
            <p class="mt-3 text-base leading-8 text-[#5d4b52]">
              The site is organized like a storefront and a discovery hub at once: readers can start by series, by mood, or by format availability without digging through menus.
            </p>
          </div>
        </div>
        <div class="space-y-4 sm:pt-12">
          <div class="card-shell animate-card-delay-2 rounded-[2.25rem] p-4">
            <BookCover book={heroBooks[1]} />
          </div>
          <div class="card-shell animate-card-delay-3 rounded-[2.25rem] p-4">
            <BookCover book={heroBooks[2]} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 pt-18 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl space-y-10">
      <SectionHeading
        eyebrow="Featured releases"
        title="Lead with the newest books, but keep the older worlds one tap away."
        description="These cards are seeded to feel like a storefront row: strong covers, immediate trope scanning, and format buttons that can later point to a direct store or retail links."
      />
      <div class="grid gap-6 lg:grid-cols-3">
        {featuredBooks.map((book) => <BookCard book={book} />)}
      </div>
    </div>
  </section>

  <section class="px-4 pt-18 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl space-y-10">
      <SectionHeading
        eyebrow="Browse by series"
        title="Seven clear entry points, each with a distinct tone."
        description="Every major series gets a branded card, a reading-order path, and a quick signal for the reader mood it serves best."
      />
      <div class="grid gap-6 lg:grid-cols-2 xl:grid-cols-3">
        {
          booksBySeries.map((item) => (
            <SeriesCard
              series={item}
              books={item.books}
              href={withBase(`series/#${item.slug}`)}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-4 pt-18 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl space-y-10">
      <SectionHeading
        eyebrow="Browse by vibe"
        title="Let readers shop by feeling, not just by metadata."
        description="The vibe cards below deep-link straight into the filtered catalog so someone can decide what to read from mood alone."
      />
      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {
          vibeCards.map((item, index) => (
            <a
              href={withBase(`books/?mood=${item.slug}`)}
              class:list={['card-shell rounded-[2rem] p-6 transition hover:-translate-y-1', `animate-card-delay-${(index % 3) + 1}`]}
            >
              <p class="eyebrow text-[#7c5a63]">Mood route</p>
              <h3 class="mt-4 font-display text-3xl text-[#241920]">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-[#5d4b52]">{item.description}</p>
              <span class="mt-6 inline-flex text-sm font-semibold text-[#241920]">
                Browse this lane →
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-4 pt-18 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <NewsletterPanel compact />
    </div>
  </section>

  <section class="px-4 pb-10 pt-18 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <SocialShowcase />
    </div>
  </section>
</BaseLayout>
