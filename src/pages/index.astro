---
import BookCover from '../components/BookCover.astro';
import NewsletterPanel from '../components/NewsletterPanel.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SeriesCard from '../components/SeriesCard.astro';
import SocialShowcase from '../components/SocialShowcase.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { booksBySeries } from '../data/catalog';
import { siteMeta } from '../data/site';
import { withBase } from '../utils/withBase';

const primaryHeroBook = booksBySeries.find((series) => series.slug === 'sons-of-the-fallen')?.books[0];
const secondaryHeroBook = booksBySeries.find((series) => series.slug === 'sent-to-a-fantasy-world')?.books[0];
const tertiaryHeroBook = booksBySeries.find((series) => series.slug === 'axios')?.books[0];
---

<BaseLayout>
  <section class="px-4 pt-8 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[1.08fr_0.92fr] lg:items-center">
      <div class="hero-shell animate-reveal overflow-hidden rounded-[2.85rem] px-6 py-10 sm:px-10 sm:py-14">
        <div class="relative z-10 max-w-2xl">
          <p class="eyebrow text-[#e7cec6]">{siteMeta.shortTagline}</p>
          <h1 class="mt-5 font-display text-[3.15rem] leading-[0.92] text-white sm:text-[4.65rem]">
            {siteMeta.heroTitle}
          </h1>
          <p class="mt-6 max-w-xl text-base leading-8 text-white/76 sm:text-lg">
            {siteMeta.heroCopy}
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href={withBase('books/')} class="button-primary">
              Browse books
            </a>
            <a href={withBase('series/')} class="button-secondary">
              Explore series
            </a>
            <a href={withBase('newsletter/')} class="button-secondary">
              Join the newsletter
            </a>
          </div>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-[0.9fr_1.1fr]">
        <div class="space-y-4">
          <div class="card-shell animate-card-delay-1 rounded-[2.25rem] p-4">
            {primaryHeroBook && <BookCover book={primaryHeroBook} />}
          </div>
        </div>
        <div class="space-y-4 sm:pt-12">
          <div class="card-shell animate-card-delay-2 rounded-[2.25rem] p-4">
            {secondaryHeroBook && <BookCover book={secondaryHeroBook} />}
          </div>
          <div class="card-shell animate-card-delay-3 rounded-[2.25rem] p-4">
            {tertiaryHeroBook && <BookCover book={tertiaryHeroBook} />}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 pt-18 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl space-y-10">
      <SectionHeading
        eyebrow="Series"
        title="Find the right series for you."
        description="Each series page lists the books in reading order and points you to the best place to begin."
      />
      <div class="grid gap-6 lg:grid-cols-2 xl:grid-cols-3">
        {
          booksBySeries.map((item) => (
            <SeriesCard
              series={item}
              books={item.books}
              href={withBase(`series/#${item.slug}`)}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-4 pt-18 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <NewsletterPanel compact />
    </div>
  </section>

  <section class="px-4 pb-10 pt-18 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <SocialShowcase />
    </div>
  </section>
</BaseLayout>
