---
import BookCard from '../components/BookCard.astro';
import PageHero from '../components/PageHero.astro';
import SeriesCard from '../components/SeriesCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { booksBySeries } from '../data/catalog';
import { withBase } from '../utils/withBase';
---

<BaseLayout
  title="Series"
  description="A series-first view of the Jaclyn Osborn catalog with dedicated lane descriptions and clear reading orders."
>
  <PageHero
    eyebrow="Series hub"
    title="Treat the catalog like a shelf of distinct worlds, not a flat list."
    description="Readers often choose by atmosphere first. This page turns each series into its own discovery lane with a clear premise, tone signal, and reading order."
    actions={[
      { href: withBase('books/'), label: 'Open the catalog', variant: 'primary' },
      { href: withBase('about/'), label: 'Meet Jaclyn', variant: 'secondary' },
    ]}
  >
    <div class="flex flex-wrap gap-3 text-sm text-white/82">
      <span class="rounded-full border border-white/14 px-3 py-2">Reading-order first</span>
      <span class="rounded-full border border-white/14 px-3 py-2">Large-backlist friendly</span>
      <span class="rounded-full border border-white/14 px-3 py-2">Mood-led navigation</span>
    </div>
  </PageHero>

  <section class="px-4 pt-10 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-2 xl:grid-cols-3">
      {
        booksBySeries.map((item) => (
          <SeriesCard series={item} books={item.books} href={`#${item.slug}`} />
        ))
      }
    </div>
  </section>

  <section class="px-4 pb-6 pt-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl space-y-8">
      {
        booksBySeries.map((item) => (
          <section
            id={item.slug}
            class="card-shell scroll-mt-28 rounded-[2.6rem] p-6 sm:p-8"
          >
            <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
              <div
                class="overflow-hidden rounded-[2.2rem] px-6 py-6"
                style={`background:linear-gradient(145deg, ${item.gradient[0]} 0%, ${item.gradient[1]} 52%, ${item.gradient[2]} 100%); color:${item.textColor};`}
              >
                <p class="text-[0.68rem] uppercase tracking-[0.34em] text-white/72">
                  {item.lane}
                </p>
                <h2 class="mt-4 font-display text-4xl leading-none sm:text-5xl">
                  {item.name}
                </h2>
                <p class="mt-4 text-base leading-8 text-white/82">
                  {item.description}
                </p>

                <div class="mt-8 grid gap-4 sm:grid-cols-2">
                  <div class="rounded-[1.6rem] border border-white/14 bg-white/8 p-4 backdrop-blur-sm">
                    <p class="eyebrow text-white/70">Status</p>
                    <p class="mt-2 text-lg font-semibold">{item.status}</p>
                  </div>
                  <div class="rounded-[1.6rem] border border-white/14 bg-white/8 p-4 backdrop-blur-sm">
                    <p class="eyebrow text-white/70">Start here</p>
                    <p class="mt-2 text-lg font-semibold">{item.entryPoint}</p>
                  </div>
                </div>

                {
                  item.highlight.length > 0 && (
                    <div class="mt-6 flex flex-wrap gap-2">
                      {item.highlight.map((tag) => <span class="pill border border-white/12 bg-white/8 text-white/86">{tag}</span>)}
                    </div>
                  )
                }
              </div>

              <div class="space-y-5">
                <div class="flex items-center justify-between gap-4">
                  <div>
                    <p class="eyebrow text-[#7c5a63]">Reading order</p>
                    <h3 class="mt-2 font-display text-3xl text-[#241920]">
                      Follow the books in sequence.
                    </h3>
                  </div>
                  <a href={withBase(`books/?series=${item.slug}&sort=series-order`)} class="button-secondary">
                    Filter catalog
                  </a>
                </div>

                <div class="grid gap-5 md:grid-cols-2">
                  {item.books.map((book) => <BookCard book={book} showSeries={false} showOrder />)}
                </div>
              </div>
            </div>
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>
