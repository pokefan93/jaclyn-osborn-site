---
import PageHero from '../components/PageHero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { booksBySeries } from '../data/catalog';
import { siteMeta } from '../data/site';
import { withBase } from '../utils/withBase';

const laneCards = [
  {
    title: 'Contemporary softness',
    copy: 'Comfort-driven romance with caretaking, emotional honesty, and strong reread energy.',
  },
  {
    title: 'Paranormal atmosphere',
    copy: 'Ghosts, witches, cursed bargains, and creature-adjacent devotion without cluttered gothic styling.',
  },
  {
    title: 'Fantasy scale',
    copy: 'Portal chaos, court stakes, magical pressure, and expansive worldbuilding anchored by clear chemistry.',
  },
  {
    title: 'Historical ache',
    copy: 'Fate, formality, and dramatic yearning for readers who want the emotional stakes dressed up.',
  },
];
---

<BaseLayout
  title="About"
  description="About Jaclyn Osborn and the brand decisions shaping this storefront-style author site."
>
  <PageHero
    eyebrow="About Jaclyn"
    title="An author brand that can hold coffee-shop comfort and magical danger at the same time."
    description={siteMeta.longBio}
    actions={[
      { href: withBase('series/'), label: 'Find your starting series', variant: 'primary' },
      { href: withBase('contact/'), label: 'Get in touch', variant: 'secondary' },
    ]}
  />

  <section class="px-4 pt-10 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-[1.05fr_0.95fr]">
      <article class="card-shell rounded-[2.4rem] p-6 sm:p-8">
        <p class="eyebrow text-[#7c5a63]">Brand cues</p>
        <h2 class="mt-4 font-display text-4xl text-[#241920] sm:text-5xl">
          Author, coffee addict, & anime lover.
        </h2>
        <p class="mt-5 text-base leading-8 text-[#5d4b52] sm:text-lg">
          The site leans into that mix instead of flattening it. Romance readers get polish and clear discovery paths, while the visuals keep a little softness, whimsy, and mood in the bloodstream.
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          <div class="rounded-[1.75rem] bg-[#f4e6e0] p-5">
            <p class="eyebrow text-[#7c5a63]">Reader promise</p>
            <p class="mt-2 text-sm leading-7 text-[#5d4b52]">
              Emotion-first M/M romance across contemporary, fantasy, paranormal, historical, and spooky lanes.
            </p>
          </div>
          <div class="rounded-[1.75rem] bg-[#e1eeec] p-5">
            <p class="eyebrow text-[#2a5a62]">Site strategy</p>
            <p class="mt-2 text-sm leading-7 text-[#41565c]">
              Treat the catalog as a discovery hub with multiple “start here” options instead of a single chronological feed.
            </p>
          </div>
        </div>
      </article>

      <article class="card-shell rounded-[2.4rem] p-6 sm:p-8">
        <p class="eyebrow text-[#7c5a63]">Writing lanes</p>
        <div class="mt-5 grid gap-4">
          {
            laneCards.map((card) => (
              <div class="rounded-[1.75rem] border border-white/60 bg-white/70 p-5">
                <h3 class="font-display text-2xl text-[#241920]">{card.title}</h3>
                <p class="mt-2 text-sm leading-7 text-[#5d4b52]">{card.copy}</p>
              </div>
            ))
          }
        </div>
      </article>
    </div>
  </section>

  <section class="px-4 pb-6 pt-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="card-shell rounded-[2.5rem] p-6 sm:p-8">
        <div class="flex flex-wrap items-start justify-between gap-6">
          <div class="max-w-2xl">
            <p class="eyebrow text-[#7c5a63]">Where to begin</p>
            <h2 class="mt-4 font-display text-4xl text-[#241920] sm:text-5xl">
              Different readers should get different doors into the catalog.
            </h2>
            <p class="mt-4 text-base leading-8 text-[#5d4b52] sm:text-lg">
              The series below function like curated shelves. Each one has a clear lane, a distinctive visual palette, and a single best entry point for new readers.
            </p>
          </div>
          <a href={withBase('series/')} class="button-secondary">
            View series hub
          </a>
        </div>

        <div class="mt-8 grid gap-5 lg:grid-cols-3">
          {
            booksBySeries.slice(0, 3).map((item) => (
              <div class="rounded-[1.85rem] bg-[#fcf7f3] p-5 shadow-[inset_0_0_0_1px_rgba(201,170,163,0.28)]">
                <p class="eyebrow text-[#7c5a63]">{item.lane}</p>
                <h3 class="mt-2 font-display text-3xl text-[#241920]">{item.name}</h3>
                <p class="mt-3 text-sm leading-7 text-[#5d4b52]">{item.description}</p>
                <p class="mt-5 text-sm font-semibold text-[#241920]">
                  Start with {item.entryPoint}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
