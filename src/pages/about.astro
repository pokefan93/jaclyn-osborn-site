---
import PageHero from '../components/PageHero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { booksBySeries } from '../data/catalog';
import { siteMeta } from '../data/site';
import { withBase } from '../utils/withBase';

const startHereSeries = [
  booksBySeries.find((item) => item.slug === 'blue-harbor'),
  booksBySeries.find((item) => item.slug === 'ivy-grove'),
  booksBySeries.find((item) => item.slug === 'sons-of-the-fallen'),
].filter((item): item is NonNullable<typeof item> => Boolean(item));

const authorPhoto = withBase('photos/jaclynosbornpicture.jpg');
---

<BaseLayout
  title="About"
  description="About Jaclyn Osborn, author of M/M romance."
>
  <PageHero
    eyebrow="About"
    title="About Jaclyn Osborn"
    description={siteMeta.longBio}
    actions={[
      { href: withBase('books/'), label: 'Browse books', variant: 'primary' },
      { href: withBase('contact/'), label: 'Get in touch', variant: 'secondary' },
    ]}
  />

  <section class="px-4 pt-10 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-[1.05fr_0.95fr]">
      <article class="card-shell rounded-[2.4rem] p-6 sm:p-8">
        <p class="eyebrow text-[#7c5a63]">About Jaclyn</p>
        <h2 class="mt-4 font-display text-4xl text-[#241920] sm:text-5xl">
          Author, coffee addict, & anime lover.
        </h2>
        <div class="mt-6 space-y-4 text-base leading-8 text-[#5d4b52] sm:text-lg">
          <p>
            Jaclyn Osborn writes M/M romance across contemporary, fantasy, paranormal,
            and historical stories.
          </p>
          <p>
            Her books are grounded in emotional connection, redemption, and the kind
            of happy ending that feels earned.
          </p>
          <p>
            If you love romance with heart, a little ache, and characters worth
            rooting for, you are in the right place.
          </p>
        </div>
      </article>

      <article class="card-shell rounded-[2.4rem] p-6 sm:p-8">
        <img
          src={authorPhoto}
          alt="Jaclyn Osborn"
          class="h-[24rem] w-full rounded-[1.9rem] object-cover object-center shadow-[0_24px_54px_rgba(36,25,32,0.14)] sm:h-[30rem]"
        />
        <div class="mt-6 space-y-4">
          <p class="eyebrow text-[#7c5a63]">Jaclyn Osborn</p>
          <p class="text-base leading-8 text-[#5d4b52] sm:text-lg">
            Contemporary, fantasy, paranormal, and historical romance with heart,
            hope, and happy endings.
          </p>
        </div>
      </article>
    </div>
  </section>

  <section class="px-4 pb-6 pt-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="card-shell rounded-[2.5rem] p-6 sm:p-8">
        <div class="flex flex-wrap items-start justify-between gap-6">
          <div class="max-w-2xl">
            <p class="eyebrow text-[#7c5a63]">Where to start</p>
            <h2 class="mt-4 font-display text-4xl text-[#241920] sm:text-5xl">
              A few easy places to begin.
            </h2>
            <p class="mt-4 text-base leading-8 text-[#5d4b52] sm:text-lg">
              Start with the series that sounds most like your kind of read, then
              follow it in order from there.
            </p>
          </div>
          <a href={withBase('series/')} class="button-secondary">
            View all series
          </a>
        </div>

        <div class="mt-8 grid gap-5 lg:grid-cols-3">
          {
            startHereSeries.map((item) => (
              <div class="rounded-[1.85rem] bg-[#fcf7f3] p-5 shadow-[inset_0_0_0_1px_rgba(201,170,163,0.28)]">
                <p class="eyebrow text-[#7c5a63]">Series</p>
                <h3 class="mt-2 font-display text-3xl text-[#241920]">{item.name}</h3>
                <p class="mt-3 text-sm leading-7 text-[#5d4b52]">{item.description}</p>
                <p class="mt-5 text-sm font-semibold text-[#241920]">
                  Start with {item.entryPoint}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
