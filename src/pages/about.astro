---
import NewsletterPanel from '../components/NewsletterPanel.astro';
import PageHero from '../components/PageHero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteMeta } from '../data/site';
import { withBase } from '../utils/withBase';

const authorPhoto = withBase('photos/jaclynosbornpicture.jpg');
---

<BaseLayout
  title="About"
  description="About Jaclyn Osborn, bestselling author of M/M romance."
>
  <PageHero
    eyebrow="About"
    title="About Jaclyn Osborn"
    description={siteMeta.longBio}
    actions={[
      { href: withBase('books/'), label: 'Browse books', variant: 'primary' },
      { href: '#about-newsletter', label: 'Join newsletter', variant: 'secondary' },
    ]}
  >
    <img
      slot="aside"
      src={authorPhoto}
      alt="Jaclyn Osborn"
      class="mx-auto h-[20rem] w-full max-w-[24rem] rounded-[2rem] object-cover object-center shadow-[0_24px_54px_rgba(36,25,32,0.22)] sm:h-[24rem] lg:mx-0 lg:h-[28rem]"
    />
  </PageHero>

  <section id="about-newsletter" class="px-4 pt-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <NewsletterPanel />
    </div>
  </section>

  <section id="about-contact" class="px-4 pb-6 pt-10 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <article class="card-shell rounded-[1.2rem] p-6 sm:p-7">
        <p class="eyebrow text-[#7c5a63]">Contact</p>
        <h2 class="mt-4 font-display text-4xl text-[#241920] sm:text-[2.8rem]">
          Get in touch.
        </h2>
        <p class="mt-4 text-base leading-8 text-[#5d4b52] sm:text-lg">
          Reader mail, event invitations, and business questions are all welcome. If
          you are not sure where to send your note, start with Jaclyn&apos;s main inbox.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={`mailto:${siteMeta.email}`} class="button-secondary">
            {siteMeta.email}
          </a>
          <a href={`mailto:${siteMeta.mediaEmail}`} class="button-secondary">
            Media & events
          </a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
