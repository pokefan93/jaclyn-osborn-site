---
export const prerender = true;

import NewsletterPanel from '../components/NewsletterPanel.astro';
import PageHero from '../components/PageHero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteMeta } from '../data/site';
import { withBase } from '../utils/withBase';

const authorPhoto = withBase('photos/jaclynosbornpicture.jpg');
---

<BaseLayout
  title="About"
  description="About Jaclyn Osborn, author of M/M romance."
>
  <PageHero
    eyebrow="About"
    title="About Jaclyn Osborn"
    description={siteMeta.longBio}
    actions={[
      { href: withBase('books/'), label: 'Browse books', variant: 'primary' },
      { href: withBase('newsletter/'), label: 'Join the newsletter', variant: 'secondary' },
    ]}
  >
    <img
      slot="aside"
      src={authorPhoto}
      alt="Jaclyn Osborn"
      class="mx-auto h-[14rem] w-full max-w-[16rem] rounded-[1.4rem] object-cover object-[50%_28%] shadow-[0_24px_54px_rgba(36,25,32,0.22)] sm:h-[18rem] sm:max-w-[18rem] sm:rounded-[1.75rem] lg:mx-0 lg:h-[20rem] lg:max-w-[19rem]"
    />
  </PageHero>

  <section class="px-4 pt-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <article class="card-shell rounded-[1.2rem] p-5 sm:p-6">
        <p class="eyebrow text-[#7c5a63]">Jaclyn</p>
        <h2 class="mt-3 font-display text-4xl text-[#241920] sm:text-[2.7rem]">
          Books across contemporary, fantasy, paranormal, and historical romance.
        </h2>
        <div class="mt-4 space-y-4 text-base leading-8 text-[#5d4b52] sm:text-lg">
          <p>
            Jaclyn Osborn writes M/M romance across contemporary, fantasy,
            paranormal, and historical stories.
          </p>
          <p>
            If you are new to her books, the books page has the full list and the
            series page shows reading order.
          </p>
        </div>
        <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a href={withBase('series/')} class="button-secondary w-full justify-center sm:w-auto">
            View series
          </a>
          <a href={siteMeta.instagramUrl} target="_blank" rel="noreferrer" class="button-secondary w-full justify-center sm:w-auto">
            Follow on Instagram
          </a>
        </div>
      </article>
    </div>
  </section>

  <section id="about-newsletter" class="px-4 pt-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <NewsletterPanel />
    </div>
  </section>

  <section id="about-contact" class="px-4 pb-6 pt-10 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <article class="card-shell rounded-[1.2rem] p-5 sm:p-6">
        <p class="eyebrow text-[#7c5a63]">Contact</p>
        <h2 class="mt-3 font-display text-4xl text-[#241920] sm:text-[2.7rem]">
          Get in touch.
        </h2>
        <p class="mt-3 text-base leading-8 text-[#5d4b52] sm:text-lg">
          For reader mail, business questions, event invites, or other work-related
          notes, visit the contact page.
        </p>
        <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a href={withBase('contact/')} class="button-secondary w-full justify-center sm:w-auto">
            Contact Jaclyn
          </a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
