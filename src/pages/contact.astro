---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/withBase';

const target = withBase('about/#about-contact');
---

<BaseLayout
  title="Contact"
  description="Contact information has moved to the About page."
>
  <section class="px-4 pt-8 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <div class="card-shell rounded-[1.2rem] p-6 text-center sm:p-8">
        <p class="eyebrow text-[#7c5a63]">Moved</p>
        <h1 class="mt-4 font-display text-4xl text-[#241920] sm:text-5xl">
          Contact has moved to About.
        </h1>
        <p class="mt-4 text-base leading-8 text-[#5d4b52] sm:text-lg">
          You will be redirected automatically. If nothing happens, use the button below.
        </p>
        <a href={target} class="button-secondary mt-6">
          Go to About
        </a>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ target }}>
    window.location.replace(target);
  </script>
</BaseLayout>
