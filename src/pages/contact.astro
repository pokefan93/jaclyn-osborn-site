---
export const prerender = true;

import PageHero from '../components/PageHero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { contactCards } from '../data/site';
import { withBase } from '../utils/withBase';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Jaclyn Osborn."
>
  <PageHero
    eyebrow="Contact"
    title="Get in touch"
    description="For reader mail, media requests, and business questions, use the email below that fits best."
    actions={[
      { href: withBase('about/'), label: 'About Jaclyn', variant: 'secondary' },
      { href: withBase('books/'), label: 'Browse books', variant: 'primary' },
    ]}
    compact
  />

  <section class="px-4 pt-10 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-5 md:grid-cols-2 xl:grid-cols-3">
      {
        contactCards.map((card) => (
          <article class="card-shell flex h-full flex-col rounded-[1.4rem] p-5 sm:p-6">
            <p class="eyebrow text-[#7c5a63]">{card.title}</p>
            <p class="mt-3 flex-1 text-base leading-8 text-[#5d4b52] sm:text-lg">
              {card.copy}
            </p>
            <a href={card.href} class="button-secondary mt-5 w-full justify-center sm:w-auto">
              {card.label}
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="px-4 pb-6 pt-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <article class="card-shell rounded-[1.2rem] p-5 sm:p-6">
        <p class="eyebrow text-[#7c5a63]">Newsletter</p>
        <h2 class="mt-3 font-display text-4xl text-[#241920] sm:text-[2.7rem]">
          Looking for release updates?
        </h2>
        <p class="mt-3 text-base leading-8 text-[#5d4b52] sm:text-lg">
          The newsletter is the best place for release news, cover reveals, and
          signed copy updates.
        </p>
        <div class="mt-5">
          <a href={withBase('newsletter/')} class="button-secondary w-full justify-center sm:w-auto">
            Visit the newsletter page
          </a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
