---
import FaqList from '../components/FaqList.astro';
import PageHero from '../components/PageHero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { contactCards, faqItems, siteMeta } from '../data/site';
import { withBase } from '../utils/withBase';
---

<BaseLayout
  title="Contact"
  description="Contact pathways for readers, media, rights, and ARC requests without any backend dependency."
>
  <PageHero
    eyebrow="Contact"
    title="Keep contact pathways clear, specific, and static-friendly."
    description="This page avoids a fake server-backed form. Instead, it gives each kind of inquiry its own route so the site stays deployable to GitHub Pages without sacrificing professionalism."
    actions={[
      { href: `mailto:${siteMeta.email}`, label: 'Email Jaclyn', variant: 'primary' },
      { href: withBase('faq/'), label: 'Read FAQ', variant: 'secondary' },
    ]}
  />

  <section class="px-4 pt-10 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-2 xl:grid-cols-4">
      {
        contactCards.map((card) => (
          <article class="card-shell rounded-[2rem] p-6">
            <p class="eyebrow text-[#7c5a63]">Contact lane</p>
            <h2 class="mt-4 font-display text-3xl text-[#241920]">{card.title}</h2>
            <p class="mt-3 text-sm leading-7 text-[#5d4b52]">{card.copy}</p>
            <a href={card.href} class="button-secondary mt-6">
              {card.label}
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="px-4 pb-6 pt-16 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.95fr_1.05fr]">
      <article class="card-shell rounded-[2.4rem] p-6 sm:p-8">
        <p class="eyebrow text-[#7c5a63]">Static-site note</p>
        <h2 class="mt-4 font-display text-4xl text-[#241920] sm:text-5xl">
          No secrets, no backend, no pretending otherwise.
        </h2>
        <p class="mt-5 text-base leading-8 text-[#5d4b52] sm:text-lg">
          GitHub Pages is enough for this build because the site keeps transactional behavior external. Newsletter signups, buy buttons, direct-store links, and email actions can all point to hosted services without shipping secrets to the frontend.
        </p>
        <div class="mt-8 rounded-[1.85rem] bg-[#fcf7f3] p-5 shadow-[inset_0_0_0_1px_rgba(201,170,163,0.28)]">
          <p class="text-sm leading-7 text-[#5d4b52]">
            Recommended next step: swap the placeholder addresses in `src/data/site.ts`, then connect newsletter and retail URLs to real hosted endpoints.
          </p>
        </div>
      </article>

      <div class="space-y-5">
        <p class="eyebrow text-[#7c5a63]">Quick answers</p>
        <FaqList items={faqItems.slice(0, 3)} />
      </div>
    </div>
  </section>
</BaseLayout>
