---
import FaqList from '../components/FaqList.astro';
import PageHero from '../components/PageHero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { faqItems } from '../data/site';
import { withBase } from '../utils/withBase';
---

<BaseLayout
  title="FAQ"
  description="Frequently asked questions for readers."
>
  <PageHero
    eyebrow="FAQ"
    title="Frequently asked questions"
    description="A few quick answers for readers."
    actions={[
      { href: withBase('books/'), label: 'Browse books', variant: 'primary' },
      { href: withBase('contact/'), label: 'Need more help?', variant: 'secondary' },
    ]}
    centered
  />

  <section class="px-4 pb-6 pt-10 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <FaqList items={faqItems} />
    </div>
  </section>
</BaseLayout>
