---
export const prerender = true;

import FaqList from '../components/FaqList.astro';
import PageHero from '../components/PageHero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { faqItems } from '../data/site';
import { withBase } from '../utils/withBase';
---

<BaseLayout
  title="FAQ"
  description="Frequently asked questions about Jaclyn Osborn's books."
>
  <PageHero
    eyebrow="FAQ"
    title="Frequently asked questions"
    description="A few quick answers about where to start, reading order, signed copies, and buying books."
    actions={[
      { href: withBase('books/'), label: 'Browse books', variant: 'primary' },
      { href: withBase('newsletter/'), label: 'Newsletter', variant: 'secondary' },
    ]}
    compact
  />

  <section class="px-4 pt-10 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <FaqList items={faqItems} />
    </div>
  </section>

  <section class="px-4 pb-6 pt-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <article class="card-shell rounded-[1.2rem] p-5 sm:p-6">
        <p class="eyebrow text-[#7c5a63]">Still have a question?</p>
        <h2 class="mt-3 font-display text-4xl text-[#241920] sm:text-[2.7rem]">
          Reach out any time.
        </h2>
        <p class="mt-3 text-base leading-8 text-[#5d4b52] sm:text-lg">
          If you do not see what you need here, the contact page has the best way to get in touch.
        </p>
        <div class="mt-5">
          <a href={withBase('contact/')} class="button-secondary w-full justify-center sm:w-auto">
            Visit the contact page
          </a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
