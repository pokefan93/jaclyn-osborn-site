---
interface Action {
  href: string;
  label: string;
  variant?: 'primary' | 'secondary';
  external?: boolean;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  actions?: Action[];
  centered?: boolean;
  compact?: boolean;
  backgroundStyle?: string;
}

const {
  eyebrow,
  title,
  description,
  actions = [],
  centered = false,
  compact = false,
  backgroundStyle,
} = Astro.props;

const hasAside = Astro.slots.has('aside');
---

<section class="px-4 pt-8 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class:list={[
      'hero-shell overflow-hidden rounded-[2.75rem] px-6 sm:px-10',
      compact ? 'py-10 sm:py-12' : 'py-12 sm:py-16',
    ]} style={backgroundStyle}>
      <div class:list={[
        'relative z-10',
        hasAside && !centered
          ? 'grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-center'
          : '',
      ]}>
        <div class:list={[
          'flex flex-col gap-6',
          centered ? 'items-center text-center' : 'max-w-3xl',
        ]}>
          <p class="eyebrow text-[#e6d2c5]">{eyebrow}</p>
          <h1 class:list={[
            'font-display leading-[0.95] text-white',
            compact ? 'text-[2.35rem] sm:text-[3.7rem]' : 'text-[2.85rem] sm:text-6xl',
          ]}>
            {title}
          </h1>
          <p class="max-w-2xl text-base leading-8 text-white/78 sm:text-lg">
            {description}
          </p>
          {
            actions.length > 0 && (
              <div class:list={['flex flex-wrap gap-3', centered && 'justify-center']}>
                {actions.map((action) => (
                  <a
                    href={action.href}
                    class={action.variant === 'secondary' ? 'button-secondary' : 'button-primary'}
                    target={action.external ? '_blank' : undefined}
                    rel={action.external ? 'noreferrer' : undefined}
                  >
                    {action.label}
                  </a>
                ))}
              </div>
            )
          }
          <slot />
        </div>

        {
          hasAside && !centered && (
            <div class="relative">
              <slot name="aside" />
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
