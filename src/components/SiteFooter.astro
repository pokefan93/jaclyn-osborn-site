---
import { navItems, siteMeta } from '../data/site';
import { withBase } from '../utils/withBase';
---

<footer class="relative z-10 px-4 pb-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="overflow-hidden rounded-[2rem] bg-[#241920] px-5 py-8 text-white shadow-[0_30px_80px_rgba(36,25,32,0.28)] sm:rounded-[2.5rem] sm:px-8 sm:py-10">
      <div class="grid gap-8 sm:gap-10 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="space-y-5">
          <h2 class="font-display text-[2.15rem] sm:text-4xl">
            M/M romance by Jaclyn Osborn.
          </h2>
          <div class="flex flex-wrap gap-3 text-sm text-white/80">
            <span class="rounded-full border border-white/15 px-3 py-2">Contemporary</span>
            <span class="rounded-full border border-white/15 px-3 py-2">Fantasy</span>
            <span class="rounded-full border border-white/15 px-3 py-2">Paranormal</span>
            <span class="rounded-full border border-white/15 px-3 py-2">Historical</span>
          </div>
        </div>

        <div class="grid gap-8 sm:grid-cols-2">
          <div class="space-y-4">
            <h3 class="text-sm font-semibold uppercase tracking-[0.28em] text-[#e6cdc4]">
              Explore
            </h3>
            <div class="grid gap-2">
              {
                navItems.map((item) => (
                  <a
                    href={withBase(item.href)}
                    class="text-sm text-white/72 transition hover:text-white"
                  >
                    {item.label}
                  </a>
                ))
              }
            </div>
          </div>

          <div class="space-y-4">
            <h3 class="text-sm font-semibold uppercase tracking-[0.28em] text-[#e6cdc4]">
              Connect
            </h3>
            <div class="grid gap-2 text-sm text-white/72">
              <a href={siteMeta.instagramUrl} target="_blank" rel="noreferrer" class="transition hover:text-white">
                Instagram
              </a>
              <a href={withBase('about/#about-newsletter')} class="transition hover:text-white">
                Newsletter
              </a>
              <a href={`mailto:${siteMeta.email}`} class="transition hover:text-white">
                {siteMeta.email}
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-10 border-t border-white/10 pt-6 text-sm text-white/55">
        <p>&copy; {new Date().getFullYear()} {siteMeta.name}. All rights reserved.</p>
        <p class="mt-2">
          Website by{' '}
          <a
            href="https://taylorstechsolutions.com"
            target="_blank"
            rel="noreferrer"
            class="text-white/72 transition hover:text-white"
          >
            Taylor&apos;s Tech Solutions
          </a>
        </p>
      </div>
    </div>
  </div>
</footer>
