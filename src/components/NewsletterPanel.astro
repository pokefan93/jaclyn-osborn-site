---
import { newsletterBenefits, siteMeta } from '../data/site';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<section class:list={['overflow-hidden rounded-[2.5rem] bg-[#241920] text-white shadow-[0_30px_80px_rgba(36,25,32,0.28)]', compact ? 'px-6 py-8 sm:px-8' : 'px-6 py-10 sm:px-10 sm:py-12']}>
  <div class:list={['grid gap-8', compact ? 'lg:grid-cols-[1.25fr_0.75fr]' : 'lg:grid-cols-[1fr_0.95fr] lg:items-center']}>
    <div class="space-y-5">
      <p class="eyebrow text-[#e7cec6]">Newsletter</p>
      <h2 class="font-display text-4xl leading-tight sm:text-5xl">
        Join Jaclyn's newsletter.
      </h2>
      <p class="max-w-2xl text-base leading-8 text-white/76">
        Release news, cover reveals, signed copy updates, and occasional notes from Jaclyn.
      </p>
      <div class="flex flex-wrap gap-2">
        {newsletterBenefits.map((benefit) => <span class="pill border border-white/12 bg-white/8 text-white/84">{benefit}</span>)}
      </div>
    </div>

    {
      compact ? (
        <div class="rounded-[2rem] border border-white/10 bg-white/6 p-6 backdrop-blur-sm">
          <p class="text-sm leading-7 text-white/76">
            New releases, cover reveals, and signed copy updates sent straight to your inbox.
          </p>
          <a
            href={siteMeta.newsletterUrl}
            class="button-primary mt-6"
          >
            Join the newsletter
          </a>
        </div>
      ) : (
        <div class="rounded-[2rem] border border-white/10 bg-white/6 p-6 backdrop-blur-sm">
          <div class="space-y-5">
            <p class="text-sm leading-7 text-white/76">
              Want to be added to the newsletter? Use the button below and Jaclyn's
              email will open with the subject line ready to go.
            </p>
            <a href={siteMeta.newsletterUrl} class="button-primary w-full justify-center">
              Join by email
            </a>
            <p class="text-sm leading-6 text-white/56">
              Release news, cover reveals, and signed copy updates.
            </p>
          </div>
        </div>
      )
    }
  </div>
</section>
