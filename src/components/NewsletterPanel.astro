---
import { newsletterBenefits, siteMeta } from '../data/site';
import { withBase } from '../utils/withBase';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<section class:list={['overflow-hidden rounded-[2rem] bg-[#241920] text-white shadow-[0_30px_80px_rgba(36,25,32,0.28)] sm:rounded-[2.5rem]', compact ? 'px-5 py-7 sm:px-8 sm:py-8' : 'px-5 py-8 sm:px-10 sm:py-12']}>
    <div class:list={['grid gap-6 sm:gap-8', compact ? 'lg:grid-cols-[1.25fr_0.75fr]' : 'lg:grid-cols-[1fr_0.95fr] lg:items-center']}>
      <div class="space-y-5">
        <p class="eyebrow text-[#e7cec6]">Newsletter</p>
        <h2 class="font-display text-[2.15rem] leading-tight sm:text-5xl">
          Join Jaclyn's newsletter.
        </h2>
        <div class="flex flex-wrap gap-2">
          {newsletterBenefits.map((benefit) => <span class="pill border border-white/12 bg-white/8 text-white/84">{benefit}</span>)}
        </div>
      </div>

    {
      compact ? (
        <div class="rounded-[1.6rem] border border-white/10 bg-white/6 p-5 backdrop-blur-sm sm:rounded-[2rem] sm:p-6">
          <p class="text-sm leading-7 text-white/76">
            New releases, cover reveals, and signed copy updates sent straight to your inbox.
          </p>
          <a
            href={withBase('about/#about-newsletter')}
            class="button-primary mt-6 w-full justify-center sm:w-auto"
          >
            Join the newsletter
          </a>
        </div>
      ) : (
        <div class="rounded-[1.6rem] border border-white/10 bg-white/6 p-5 backdrop-blur-sm sm:rounded-[2rem] sm:p-6">
          <div class="space-y-5">
            <p class="text-sm leading-6 text-white/56">
              Release news, cover reveals, book updates, and more from Jaclyn.
            </p>
            <div>
              <label
                for="newsletter-email-input"
                class="mb-2 block text-sm font-semibold text-white/82"
              >
                Email address
              </label>
              <input
                id="newsletter-email-input"
                type="email"
                name="newsletter_email"
                placeholder="Subscribe to Jaclyn's newsletter"
                class="input-shell"
                data-newsletter-email-input
              />
            </div>
            <button
              type="button"
              class="button-primary w-full justify-center"
              data-newsletter-email-trigger
              data-newsletter-target={siteMeta.email}
            >
              Join by email
            </button>
          </div>
        </div>
      )
    }
  </div>
</section>

<script>
  const trigger = document.querySelector('[data-newsletter-email-trigger]');
  const emailInput = document.querySelector('[data-newsletter-email-input]');

  if (trigger instanceof HTMLButtonElement && emailInput instanceof HTMLInputElement) {
    trigger.addEventListener('click', () => {
      const typedEmail = emailInput.value.trim();
      const target = trigger.dataset.newsletterTarget ?? '';
      const subject = 'Newsletter Signup';
      const body = typedEmail
        ? `Please add this email to Jaclyn's newsletter list:\n\n${typedEmail}`
        : `Please add me to Jaclyn's newsletter list.`;

      window.location.href = `mailto:${target}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    });
  }
</script>
