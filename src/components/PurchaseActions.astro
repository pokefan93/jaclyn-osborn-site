---
import { formatLabels } from '../data/catalog';
import { siteMeta } from '../data/site';
import type { Book } from '../types/catalog';
import {
  getAvailabilityLabel,
  getMerchandisingFlags,
  getPurchaseSupportNotes,
  merchandisingFlagLabels,
} from '../utils/purchase';
import StripeBuyButton from './StripeBuyButton.astro';

interface Props {
  book: Book;
  compact?: boolean;
}

const { book, compact = false } = Astro.props;

const isPlaceholderUrl = (url?: string) =>
  !url ||
  url.includes('example.com') ||
  url.includes('buy.stripe.com/test_');

const liveDirectFormats = book.purchase.directSaleFormats.filter((format) => {
  if (format.purchaseMode === 'unavailable') {
    return false;
  }

  if (format.purchaseMode === 'stripe_buy_button') {
    return Boolean(format.stripeBuyButtonId) || !isPlaceholderUrl(format.purchaseUrl);
  }

  return !isPlaceholderUrl(format.purchaseUrl);
});

const liveRetailerLinks = book.purchase.retailerLinks.filter(
  (retailer) => !isPlaceholderUrl(retailer.purchaseUrl),
);

const hasLivePurchaseOptions =
  liveDirectFormats.length > 0 || liveRetailerLinks.length > 0;

const merchandisingFlags = hasLivePurchaseOptions ? getMerchandisingFlags(book) : [];
const availabilityLabel = getAvailabilityLabel(book.purchase);
const supportNotes = hasLivePurchaseOptions
  ? getPurchaseSupportNotes(book, siteMeta.directSales)
  : [];

const showAvailability =
  hasLivePurchaseOptions &&
  (book.purchase.directFromAuthor ||
    liveDirectFormats.length > 0 ||
    book.purchase.availabilityStatus !== 'in_stock');

const showWhereToBuyLabel =
  liveDirectFormats.length > 0 && liveRetailerLinks.length > 0;

const showStatusRow = merchandisingFlags.length > 0 || showAvailability;
const showDirectComingSoon =
  liveDirectFormats.length === 0 &&
  (book.purchase.directSaleFormats.length > 0 ||
    book.purchase.directFromAuthor ||
    book.purchase.signedCopy);
const showRetailComingSoon =
  liveRetailerLinks.length === 0 && book.purchase.retailerLinks.length > 0;

const showPurchaseContent =
  showStatusRow ||
  Boolean(book.purchase.priceNote) ||
  liveDirectFormats.length > 0 ||
  liveRetailerLinks.length > 0 ||
  showDirectComingSoon ||
  showRetailComingSoon ||
  supportNotes.length > 0;

const availabilityTone =
  book.purchase.availabilityStatus === 'preorder'
    ? 'status-pill status-pill-preorder'
    : book.purchase.availabilityStatus === 'limited'
      ? 'status-pill status-pill-limited'
      : book.purchase.availabilityStatus === 'sold_out'
        ? 'status-pill status-pill-soldout'
        : 'status-pill status-pill-stock';
---

{
  showPurchaseContent && (
    <div class="mt-6 space-y-4">
      {
        showStatusRow && (
          <div class="flex flex-wrap gap-2">
            {
              merchandisingFlags.map((flag) => (
                <span
                  class:list={[
                    'pill',
                    flag === 'new_release' && 'bg-[#241920] text-white',
                    flag === 'signed_copy' && 'bg-[#e8d0bc] text-[#6d4656]',
                    flag === 'audiobook_available' && 'bg-[#d8ece9] text-[#23404c]',
                    flag === 'direct_from_author' && 'bg-[#ede2ea] text-[#6d4656]',
                    flag === 'preorder' && 'bg-[#efe3c8] text-[#6f4c1c]',
                  ]}
                >
                  {merchandisingFlagLabels[flag]}
                </span>
              ))
            }
            {
              showAvailability && (
                <span class={availabilityTone}>
                  {availabilityLabel}
                </span>
              )
            }
          </div>
        )
      }

      {
        book.purchase.priceNote && (
          <div class="space-y-2 rounded-[1.4rem] bg-[#fcf7f3] px-4 py-4 shadow-[inset_0_0_0_1px_rgba(201,170,163,0.22)]">
            <p class="eyebrow text-[#7c5a63]">
              Amazon snapshot
              {book.purchase.priceSnapshotDate ? ` (${book.purchase.priceSnapshotDate})` : ''}
            </p>
            <p class="text-sm leading-7 text-[#5d4b52]">{book.purchase.priceNote}</p>
          </div>
        )
      }

      {
        liveDirectFormats.length > 0 && (
          <div class="space-y-2">
            <div class="flex items-center justify-between gap-3">
              <p class="eyebrow text-[#7c5a63]">
                {book.purchase.directFromAuthor ? 'Direct from Jaclyn' : 'Direct shop'}
              </p>
            </div>

            <div class:list={[compact ? 'grid gap-2' : 'flex flex-wrap gap-2']}>
              {
                liveDirectFormats.map((format) => {
                  const label = `${format.label} - ${formatLabels[format.format]}`;

                  if (format.purchaseMode === 'stripe_buy_button' && format.stripeBuyButtonId) {
                    return (
                      <StripeBuyButton
                        buyButtonId={format.stripeBuyButtonId}
                        fallbackUrl={format.purchaseUrl ?? undefined}
                        fallbackLabel={label}
                      />
                    );
                  }

                  return (
                    <a
                      href={format.purchaseUrl ?? '#'}
                      target="_blank"
                      rel="noreferrer"
                      class:list={[
                        'format-button',
                        compact && 'w-full justify-center',
                        format.purchaseMode === 'stripe_payment_link' && 'purchase-direct',
                      ]}
                    >
                      {label}
                    </a>
                  );
                })
              }
            </div>
          </div>
        )
      }

      {
        showDirectComingSoon && (
          <div class="space-y-2">
            <p class="eyebrow text-[#7c5a63]">
              {book.purchase.signedCopy ? 'Signed copies' : 'Direct shop'}
            </p>
            <span class="purchase-disabled">
              {book.purchase.signedCopy
                ? 'Signed copies coming soon'
                : 'Direct shop updates coming soon'}
            </span>
          </div>
        )
      }

      {
        liveRetailerLinks.length > 0 && (
          <div class="space-y-2">
            <p class="eyebrow text-[#7c5a63]">
              {showWhereToBuyLabel ? 'Retailers' : 'Where to buy'}
            </p>
            <div class:list={[compact ? 'grid gap-2' : 'flex flex-wrap gap-2']}>
              {
                liveRetailerLinks.map((retailer) => (
                  <a
                    href={retailer.purchaseUrl}
                    target="_blank"
                    rel="noreferrer"
                    class:list={['format-button', compact && 'w-full justify-center']}
                  >
                    {retailer.label}
                  </a>
                ))
              }
            </div>
          </div>
        )
      }

      {
        showRetailComingSoon && (
          <div class="space-y-2">
            <p class="eyebrow text-[#7c5a63]">Retailers</p>
            <span class="purchase-disabled">Retailer links coming soon</span>
          </div>
        )
      }

      {
        supportNotes.length > 0 && (
          <div class:list={['space-y-2 rounded-[1.4rem] bg-[#fcf7f3] px-4 py-4 shadow-[inset_0_0_0_1px_rgba(201,170,163,0.22)]', compact && 'text-xs']}>
            {supportNotes.map((note) => <p class="purchase-note">{note}</p>)}
          </div>
        )
      }
    </div>
  )
}
