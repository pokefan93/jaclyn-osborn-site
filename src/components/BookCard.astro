---
import { getBookCollectionLabel } from '../data/catalog';
import type { Book } from '../types/catalog';
import BookCover from './BookCover.astro';
import PurchaseActions from './PurchaseActions.astro';

interface Props {
  book: Book;
  showSeries?: boolean;
  showOrder?: boolean;
}

const { book, showSeries = true, showOrder = false } = Astro.props;
const collectionLabel = getBookCollectionLabel(book);
const releaseYear = /^\d{4}/.test(book.releaseDate)
  ? new Date(book.releaseDate).getFullYear()
  : null;
const hasSeriesOrder = book.seriesOrder > 0 && Boolean(book.seriesSlug || book.seriesLabel);
---

<article class="card-shell group flex h-full flex-col rounded-[1.2rem] p-4">
  <div class="relative">
    {
      showOrder && hasSeriesOrder && (
        <span class="absolute left-4 top-4 z-10 rounded-full bg-white/88 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-[#241920] shadow-[0_12px_24px_rgba(36,25,32,0.16)]">
          Book {book.seriesOrder}
        </span>
      )
    }
    <BookCover book={book} />
  </div>

  <div class="flex flex-1 flex-col px-1 pb-1 pt-5">
    <div class="flex flex-wrap gap-2">
      {
        showSeries && collectionLabel && (
          <span class="pill bg-[#f4e6e0] text-[#6d4656]">
            {collectionLabel}
          </span>
        )
      }
    </div>

    <h3 class="mt-4 font-display text-[2rem] leading-[1.02] text-[#241920]">
      {book.title}
    </h3>
    {
      releaseYear && (
        <p class="mt-3 text-xs font-semibold uppercase tracking-[0.24em] text-[#7c5a63]">
          Published {releaseYear}
        </p>
      )
    }
    <p class="mt-3 text-sm leading-7 text-[#5d4b52] sm:text-[0.96rem]">
      {book.shortHook}
    </p>

    <PurchaseActions book={book} compact />

    <div class="mt-auto pt-6 text-sm text-[#6e5961]">
      {
        hasSeriesOrder
          ? `${collectionLabel} - Book ${book.seriesOrder}`
          : collectionLabel
      }
    </div>
  </div>
</article>
