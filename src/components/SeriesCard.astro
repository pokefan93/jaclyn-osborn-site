---
import type { Book, Series } from '../types/catalog';
import BookCover from './BookCover.astro';

interface Props {
  series: Series;
  books: Book[];
  href: string;
}

const { series, books, href } = Astro.props;
const [primaryBook, secondaryBook] = books;
---

<a href={href} class="group block h-full rounded-[1.2rem] focus-visible:outline-2 focus-visible:outline-offset-6 focus-visible:outline-[#241920]">
  <article class="card-shell flex h-full min-h-[24.5rem] flex-col overflow-hidden rounded-[1.2rem] sm:min-h-[25.5rem]">
    <div
      class="relative overflow-hidden px-5 py-5 sm:px-6 sm:py-6"
      style={`background:linear-gradient(145deg, ${series.gradient[0]} 0%, ${series.gradient[1]} 52%, ${series.gradient[2]} 100%); color:${series.textColor};`}
    >
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.2),transparent_42%)]"></div>
      <div class="relative z-10 grid min-h-[14rem] grid-cols-[minmax(0,1fr)_9.75rem] gap-4 sm:min-h-[15rem] sm:grid-cols-[minmax(0,1fr)_11.5rem] sm:gap-5">
        <div class="pr-1">
          <p class="text-[0.68rem] uppercase tracking-[0.36em] text-white/70">
            {series.lane}
          </p>
          <h3 class="mt-3 font-display text-[1.95rem] leading-none sm:text-[2.2rem]">
            {series.name}
          </h3>
          <p class="mt-4 max-w-[14rem] text-sm leading-6 text-white/82">
            {series.tagline}
          </p>
        </div>

        <div class="relative min-h-[11rem]">
          {
            primaryBook && (
              <div class="absolute bottom-0 left-0 z-10 w-[6.2rem] rotate-[-8deg] transition duration-500 group-hover:-translate-y-1 sm:w-[7.1rem]">
                <BookCover book={primaryBook} className="rounded-[0.8rem]" />
              </div>
            )
          }
          {
            secondaryBook && (
              <div class="absolute bottom-0 right-0 z-20 w-[6.75rem] rotate-[7deg] transition duration-500 group-hover:-translate-y-2 sm:w-[7.75rem]">
                <BookCover book={secondaryBook} className="rounded-[0.8rem]" />
              </div>
            )
          }
        </div>
      </div>
    </div>

    <div class="flex flex-1 flex-col gap-4 p-5 sm:p-6">
      <p class="text-sm leading-6 text-[#5d4b52]">
        {series.description}
      </p>
      <p class="text-sm font-semibold text-[#241920]">
        Start with {series.entryPoint}
      </p>
      <div class="mt-auto flex items-center justify-between gap-4 pt-2 text-sm">
        <span class="text-[#6e5961]">{books.length} books</span>
        <span class="font-semibold text-[#241920] transition group-hover:translate-x-1">
          Explore series
        </span>
      </div>
    </div>
  </article>
</a>
