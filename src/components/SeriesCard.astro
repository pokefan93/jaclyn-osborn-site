---
import type { Book, Series } from '../types/catalog';
import BookCover from './BookCover.astro';

interface Props {
  series: Series;
  books: Book[];
  href: string;
}

const { series, books, href } = Astro.props;
const [primaryBook, secondaryBook] = books;
const hasLongName = series.name.length > 28;
---

<a href={href} class="group block h-full rounded-[1.2rem] focus-visible:outline-2 focus-visible:outline-offset-6 focus-visible:outline-[#241920]">
  <article class="card-shell flex h-full min-h-[21.75rem] flex-col overflow-hidden rounded-[1.2rem] sm:min-h-[22.9rem]">
    <div
      class="relative overflow-hidden px-4 py-4 sm:px-5 sm:py-5"
      style={`background:linear-gradient(145deg, ${series.gradient[0]} 0%, ${series.gradient[1]} 52%, ${series.gradient[2]} 100%); color:${series.textColor};`}
    >
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.2),transparent_42%)]"></div>
      <div
        class:list={[
          'relative z-10 grid min-h-[12.25rem] items-start gap-3 sm:min-h-[13rem] sm:gap-4',
          hasLongName
            ? 'grid-cols-[minmax(0,1.16fr)_7.9rem] sm:grid-cols-[minmax(0,1.18fr)_9.1rem]'
            : 'grid-cols-[minmax(0,1fr)_8.6rem] sm:grid-cols-[minmax(0,1fr)_10rem]',
        ]}
      >
        <div class="pr-1">
          <p class="text-[0.68rem] uppercase tracking-[0.36em] text-white/70">
            {series.lane}
          </p>
          <h3
            class:list={[
              'mt-3 font-display',
              hasLongName
                ? 'text-[1.44rem] leading-[0.94] tracking-[-0.045em] sm:text-[1.7rem]'
                : 'text-[1.8rem] leading-none sm:text-[2.05rem]',
            ]}
          >
            {series.name}
          </h3>
          <p class:list={['mt-3 text-sm leading-5 text-white/82 sm:leading-6', hasLongName ? 'max-w-[12.4rem]' : 'max-w-[13.4rem]']}>
            {series.tagline}
          </p>
        </div>

        <div class="relative min-h-[9.2rem] sm:min-h-[10rem]">
          {
            primaryBook && (
              <div class="absolute right-[2.45rem] top-2 z-10 w-[5.45rem] rotate-[-8deg] transition duration-500 group-hover:-translate-y-1 sm:right-[2.9rem] sm:top-2 sm:w-[6.3rem]">
                <BookCover book={primaryBook} className="rounded-[0.8rem]" />
              </div>
            )
          }
          {
            secondaryBook && (
              <div class="absolute right-0 top-0 z-20 w-[5.95rem] rotate-[7deg] transition duration-500 group-hover:-translate-y-2 sm:w-[6.9rem]">
                <BookCover book={secondaryBook} className="rounded-[0.8rem]" />
              </div>
            )
          }
        </div>
      </div>
    </div>

    <div class="flex flex-1 flex-col gap-3 p-4 sm:p-5">
      <p class="text-sm leading-6 text-[#5d4b52]">
        {series.description}
      </p>
      <p class="text-sm font-semibold text-[#241920]">
        Start with {series.entryPoint}
      </p>
      <div class="mt-auto flex flex-col items-start gap-2 pt-1 text-sm sm:flex-row sm:items-center sm:justify-between">
        <span class="text-[#6e5961]">{books.length} books</span>
        <span class="font-semibold text-[#241920] transition group-hover:translate-x-1">
          Explore series
        </span>
      </div>
    </div>
  </article>
</a>
