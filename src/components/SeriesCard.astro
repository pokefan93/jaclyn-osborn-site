---
import type { Book, Series } from '../types/catalog';
import BookCover from './BookCover.astro';

interface Props {
  series: Series;
  books: Book[];
  href: string;
}

const { series, books, href } = Astro.props;
const [primaryBook, secondaryBook] = books;
---

<a href={href} class="group block h-full rounded-[1.35rem] focus-visible:outline-2 focus-visible:outline-offset-6 focus-visible:outline-[#241920]">
  <article class="card-shell flex h-full min-h-[29rem] flex-col overflow-hidden rounded-[1.35rem] sm:min-h-[31rem]">
    <div
      class="relative overflow-hidden px-6 py-6 sm:px-7 sm:py-7"
      style={`background:linear-gradient(145deg, ${series.gradient[0]} 0%, ${series.gradient[1]} 52%, ${series.gradient[2]} 100%); color:${series.textColor};`}
    >
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.2),transparent_42%)]"></div>
      <div class="relative z-10 max-w-[16rem] sm:max-w-[18rem]">
        <p class="text-[0.68rem] uppercase tracking-[0.36em] text-white/70">
          {series.lane}
        </p>
        <h3 class="mt-3 font-display text-[2.15rem] leading-none sm:text-[2.45rem]">
          {series.name}
        </h3>
        <p class="mt-4 text-sm leading-7 text-white/82 sm:text-base">
          {series.tagline}
        </p>
      </div>

      <div class="relative z-10 mt-8 flex items-end justify-end gap-2">
        {
          primaryBook && (
            <div class="w-16 rotate-[-8deg] transition duration-500 group-hover:-translate-y-1 sm:w-[4.5rem]">
              <BookCover book={primaryBook} className="rounded-[0.8rem]" />
            </div>
          )
        }
        {
          secondaryBook && (
            <div class="w-16 rotate-[7deg] transition duration-500 group-hover:-translate-y-2 sm:w-[4.5rem]">
              <BookCover book={secondaryBook} className="rounded-[0.8rem]" />
            </div>
          )
        }
      </div>
    </div>

    <div class="flex flex-1 flex-col gap-4 p-6 sm:p-7">
      <p class="text-sm leading-7 text-[#5d4b52] sm:text-base">
        {series.description}
      </p>
      <p class="text-sm font-semibold text-[#241920]">
        Start with {series.entryPoint}
      </p>
      <div class="mt-auto flex items-center justify-between gap-4 pt-2 text-sm">
        <span class="text-[#6e5961]">{books.length} books</span>
        <span class="font-semibold text-[#241920] transition group-hover:translate-x-1">
          Explore series
        </span>
      </div>
    </div>
  </article>
</a>
