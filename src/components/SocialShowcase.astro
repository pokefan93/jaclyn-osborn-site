---
import { siteMeta, socialPreviewCards } from '../data/site';
---

<section class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
  <div class="space-y-5">
    <p class="eyebrow text-[#7c5a63]">Social</p>
    <h2 class="font-display text-4xl leading-tight text-[#241920] sm:text-5xl">
      Give readers a place for coffee-fueled chaos between releases.
    </h2>
    <p class="text-base leading-8 text-[#5f4d54] sm:text-lg">
      The Instagram zone is built for personality: cover teases, anime tangents, signed-copy drops, desk details, and launch-week momentum that keeps the storefront feeling alive.
    </p>
    <a href={siteMeta.instagramUrl} target="_blank" rel="noreferrer" class="button-secondary">
      Visit Instagram
    </a>
  </div>

  <div class="grid gap-4 sm:grid-cols-3">
    {
      socialPreviewCards.map((item, index) => (
        <article class:list={['card-shell rounded-[1.9rem] p-4', `animate-card-delay-${index + 1}`]}>
          <div class={`h-44 rounded-[1.5rem] bg-gradient-to-br ${item.accent}`}></div>
          <h3 class="mt-4 font-display text-2xl text-[#241920]">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-[#5d4b52]">{item.copy}</p>
        </article>
      ))
    }
  </div>
</section>
