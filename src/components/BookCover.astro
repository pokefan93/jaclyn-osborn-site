---
import type { Book } from '../types/catalog';
import { withBase } from '../utils/withBase';

interface Props {
  book: Book;
  className?: string;
}

const { book, className = '' } = Astro.props;

const paletteMap = {
  rose: {
    gradient: 'linear-gradient(160deg, #f2dfd3 0%, #cf8a7b 48%, #6f425e 100%)',
    glow: '#f7e7de',
  },
  plum: {
    gradient: 'linear-gradient(155deg, #2a1c2a 0%, #6f425e 52%, #d19b89 100%)',
    glow: '#f3ddd4',
  },
  teal: {
    gradient: 'linear-gradient(155deg, #21424b 0%, #6fa4b7 52%, #dbe9e5 100%)',
    glow: '#f3fbfb',
  },
  gold: {
    gradient: 'linear-gradient(160deg, #2f2738 0%, #8a6f63 45%, #d8b272 100%)',
    glow: '#fff7e7',
  },
  cobalt: {
    gradient: 'linear-gradient(160deg, #1d2743 0%, #466d9f 50%, #dbc279 100%)',
    glow: '#f4f6fb',
  },
  sage: {
    gradient: 'linear-gradient(150deg, #213735 0%, #769b8a 54%, #efe3cb 100%)',
    glow: '#f8f4ec',
  },
  ember: {
    gradient: 'linear-gradient(155deg, #2a1c23 0%, #9a5d5a 45%, #dfb07e 100%)',
    glow: '#fcf1e6',
  },
} as const;

const palette = paletteMap[book.coverPalette];
const coverSrc = withBase(book.coverImageUrl ?? `covers/${book.slug}.jpg`);
const releaseYear = /^\d{4}/.test(book.releaseDate)
  ? new Date(book.releaseDate).getFullYear()
  : null;
---

<div
  class:list={[
    'relative aspect-[0.72] overflow-hidden rounded-[1rem] border border-white/20 shadow-[0_24px_54px_rgba(36,25,32,0.18)]',
    className,
  ]}
  style={`background:${palette.gradient};`}
>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.32),transparent_45%),radial-gradient(circle_at_bottom_right,rgba(255,255,255,0.18),transparent_40%)]"></div>
  <div class="absolute inset-0 opacity-30 [background-image:linear-gradient(135deg,rgba(255,255,255,0.35)_0%,transparent_36%),linear-gradient(320deg,rgba(255,255,255,0.08)_0%,transparent_42%)]"></div>
  <div class="absolute left-5 top-5 h-14 w-14 rounded-full border border-white/30 bg-white/12 backdrop-blur-sm"></div>
  <div class="absolute bottom-4 left-4 right-4 rounded-[0.8rem] border border-white/16 bg-black/10 px-4 py-4 backdrop-blur-sm">
    <p class="text-[10px] uppercase tracking-[0.32em] text-white/78">
      Jaclyn Osborn
    </p>
    <h3 class="mt-2 font-display text-[1.65rem] leading-[1] text-white">
      {book.title}
    </h3>
    {
      releaseYear && (
        <p class="mt-3 text-[0.68rem] uppercase tracking-[0.28em] text-white/70">
          {releaseYear}
        </p>
      )
    }
  </div>
  <div
    class="absolute bottom-0 left-0 right-0 h-2"
    style={`background:${palette.glow};`}
  ></div>
  <img
    src={coverSrc}
    alt={`Cover of ${book.title} by Jaclyn Osborn`}
    class="absolute inset-0 z-20 h-full w-full object-cover"
    loading="lazy"
    decoding="async"
    onerror="this.remove()"
  />
</div>
