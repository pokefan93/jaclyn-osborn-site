---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  centered?: boolean;
}

const {
  eyebrow,
  title,
  description,
  centered = false,
} = Astro.props;
---

<div class:list={['space-y-4', centered && 'mx-auto max-w-3xl text-center']}>
  <p class="eyebrow text-[#7c5a63]">{eyebrow}</p>
  <h2 class="font-display text-[2.15rem] leading-tight text-[#241920] sm:text-5xl">
    {title}
  </h2>
  {
    description && (
      <p class="text-[0.98rem] leading-7 text-[#5f4d54] sm:text-lg sm:leading-8">
        {description}
      </p>
    )
  }
</div>
