---
import { navItems, siteMeta } from '../data/site';
import { withBase } from '../utils/withBase';

const normalizedPath = (() => {
  const withoutBase = Astro.url.pathname.replace(import.meta.env.BASE_URL, '/');
  const path = withoutBase.startsWith('/') ? withoutBase : `/${withoutBase}`;

  return path.endsWith('/') ? path : `${path}/`;
})();

const isActive = (href: string) => normalizedPath === href;
---

<header class="sticky top-0 z-50 px-3 pt-3 sm:px-6 sm:pt-4 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="glass-panel flex items-center justify-between gap-3 rounded-[1.7rem] px-3 py-2.5 sm:gap-4 sm:rounded-[2rem] sm:px-5 sm:py-3">
      <a
        href={withBase('')}
        class="group inline-flex max-w-[calc(100%-3.5rem)] min-w-0 items-center gap-2.5 rounded-full focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#241920] sm:gap-3 md:max-w-none"
      >
        <span
          class="h-11 w-11 shrink-0 overflow-hidden rounded-full border border-white/55 bg-[#f4e6e0] shadow-[0_16px_30px_rgba(111,66,94,0.22)] sm:h-12 sm:w-12"
        >
          <img
            src={withBase('photos/jaclynosbornpicture.jpg')}
            alt="Portrait of Jaclyn Osborn"
            class="h-full w-full scale-115 object-cover object-center"
            loading="eager"
            decoding="async"
          />
        </span>
        <span class="min-w-0 pr-1">
          <span class="site-brand-title block overflow-visible whitespace-nowrap pl-[0.1em] pr-[0.08em] pt-[0.08em] pb-[0.06em] font-display text-[1.22rem] font-semibold italic leading-[1.03] tracking-[-0.03em] sm:text-[1.62rem] sm:tracking-[-0.035em]">
            {siteMeta.name}
          </span>
          <span class="site-brand-subtitle mt-1 block truncate text-[0.62rem] uppercase tracking-[0.18em] sm:text-xs sm:tracking-[0.28em]">
            BESTSELLING M/M ROMANCE AUTHOR
          </span>
        </span>
      </a>

      <div class="hidden items-center gap-2 md:flex">
        <nav class="flex items-center gap-1" aria-label="Primary">
          {
            navItems.map((item) => (
              <a
                href={withBase(item.href)}
                class:list={[
                  'site-nav-link rounded-full px-4 py-2 text-sm font-semibold transition',
                  isActive(item.href) && 'is-active',
                ]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </nav>

        <button
          type="button"
          class="theme-toggle"
          data-theme-toggle
          aria-label="Switch to dark mode"
          aria-pressed="false"
        >
          <span class="sr-only">Toggle dark mode</span>
          <svg data-theme-icon="sun" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2.5"></path>
            <path d="M12 19.5V22"></path>
            <path d="M4.93 4.93l1.77 1.77"></path>
            <path d="M17.3 17.3l1.77 1.77"></path>
            <path d="M2 12h2.5"></path>
            <path d="M19.5 12H22"></path>
            <path d="M4.93 19.07l1.77-1.77"></path>
            <path d="M17.3 6.7l1.77-1.77"></path>
          </svg>
          <svg data-theme-icon="moon" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.8A8.98 8.98 0 1 1 11.2 3c-.2.64-.3 1.32-.3 2a7.3 7.3 0 0 0 7.3 7.3c.68 0 1.36-.1 2-.3Z"></path>
          </svg>
        </button>
      </div>

      <div class="flex items-center gap-2 md:hidden">
        <button
          type="button"
          class="theme-toggle"
          data-theme-toggle
          aria-label="Switch to dark mode"
          aria-pressed="false"
        >
          <span class="sr-only">Toggle dark mode</span>
          <svg data-theme-icon="sun" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2.5"></path>
            <path d="M12 19.5V22"></path>
            <path d="M4.93 4.93l1.77 1.77"></path>
            <path d="M17.3 17.3l1.77 1.77"></path>
            <path d="M2 12h2.5"></path>
            <path d="M19.5 12H22"></path>
            <path d="M4.93 19.07l1.77-1.77"></path>
            <path d="M17.3 6.7l1.77-1.77"></path>
          </svg>
          <svg data-theme-icon="moon" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.8A8.98 8.98 0 1 1 11.2 3c-.2.64-.3 1.32-.3 2a7.3 7.3 0 0 0 7.3 7.3c.68 0 1.36-.1 2-.3Z"></path>
          </svg>
        </button>

        <button
          type="button"
          class="site-header-button"
          data-nav-toggle
          aria-expanded="false"
          aria-controls="mobile-nav"
        >
          <span class="sr-only">Toggle navigation</span>
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <path d="M4 7h16" />
            <path d="M4 12h16" />
            <path d="M4 17h16" />
          </svg>
        </button>
      </div>
    </div>

    <div
      id="mobile-nav"
      class="glass-panel mt-3 hidden rounded-[1.7rem] px-3 py-3.5 md:hidden sm:rounded-[2rem] sm:px-4 sm:py-4"
      data-nav-panel
    >
      <nav class="grid gap-2" aria-label="Mobile primary">
        {
          navItems.map((item) => (
            <a
              href={withBase(item.href)}
              class:list={[
                'site-mobile-nav-link rounded-[1.25rem] px-4 py-3 text-sm font-semibold transition',
                isActive(item.href) && 'is-active',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</header>

<script>
  const root = document.documentElement;
  const themeStorageKey = 'jaclyn-theme';
  const themeButtons = Array.from(
    document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]'),
  );
  const themeMeta = document.querySelector<HTMLMetaElement>('meta[data-theme-color]');
  const button = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const panel = document.querySelector<HTMLElement>('[data-nav-panel]');

  const syncThemeUi = () => {
    const isDark = root.dataset.theme === 'dark';

    themeButtons.forEach((themeButton) => {
      themeButton.setAttribute('aria-pressed', String(isDark));
      themeButton.setAttribute(
        'aria-label',
        isDark ? 'Switch to light mode' : 'Switch to dark mode',
      );
    });

    if (themeMeta) {
      themeMeta.content = isDark ? '#120e15' : '#241920';
    }
  };

  const applyTheme = (theme: 'light' | 'dark') => {
    root.dataset.theme = theme;
    root.classList.toggle('theme-dark', theme === 'dark');

    try {
      localStorage.setItem(themeStorageKey, theme);
    } catch {}

    syncThemeUi();
  };

  syncThemeUi();

  themeButtons.forEach((themeButton) => {
    themeButton.addEventListener('click', () => {
      applyTheme(root.dataset.theme === 'dark' ? 'light' : 'dark');
    });
  });

  if (button && panel) {
    button.addEventListener('click', () => {
      const expanded = button.getAttribute('aria-expanded') === 'true';
      button.setAttribute('aria-expanded', String(!expanded));
      panel.classList.toggle('hidden', expanded);
    });

    panel.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        button.setAttribute('aria-expanded', 'false');
        panel.classList.add('hidden');
      });
    });
  }
</script>
